generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                   @id @default(cuid())
  discordId           String?                  @unique
  name                String
  email               String?                  @unique
  emailVerified       Boolean?
  image               String?                  @db.Text
  role                String                   @default("USER")
  playerId            String?
  balance             Float                    @default(0)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  acceptedTerms       Boolean                  @default(false)
  appearance          String?                  @db.LongText
  clothes             String?                  @db.LongText
  deaths              Int                      @default(0)
  exp                 Int                      @default(0)
  gender              String?
  guildCooldownEndsAt DateTime?
  hasPriority         Boolean                  @default(false)
  isDiscordActive     Boolean                  @default(true)
  isOnline            Boolean                  @default(false)
  isVerified          Boolean                  @default(false)
  isWhitelisted       Boolean                  @default(false)
  kills               Int                      @default(0)
  lastLoginAt         DateTime?
  level               Int                      @default(0)
  license             String?
  playedTime          Int                      @default(0)
  referral            String?                  @default("Nenhum")
  slug                String?
  steam               String?
  tattoos             String?                  @db.LongText
  vehicleLiveries     String?                  @db.LongText
  weaponSkins         String?                  @db.LongText
  wins                Int                      @default(0)
  vipExpiresAt        DateTime?
  headshots           Int                      @default(0)
  armKills            Int                      @default(0)
  gamePlayerId        Int?                     @unique
  legKills            Int                      @default(0)
  torsoKills          Int                      @default(0)
  totalMatches        Int                      @default(0)
  accounts            Account[]
  auditLogs           AuditLog[]
  bansIssued          Ban[]                    @relation("BanIssuer")
  bans                Ban[]                    @relation("BannedUser")
  favorites           Favorite[]
  gameParticipations  GamePlayer[]
  gameStats           GameStats[]
  gcoinTransactions   GCoinTransaction[]
  guildMembership     GuildMember?
  ownedGuilds         Guild[]                  @relation("GuildOwner")
  marketBuying        MarketplaceListing[]     @relation("MarketplaceBuyer")
  marketSelling       MarketplaceListing[]     @relation("MarketplaceSeller")
  marketBoughtTx      MarketplaceTransaction[] @relation("TransactionBuyer")
  marketSoldTx        MarketplaceTransaction[] @relation("TransactionSeller")
  receivedMessages    Message[]                @relation("ReceivedMessages")
  sentMessages        Message[]                @relation("SentMessages")
  orders              Order[]
  playerClothes       PlayerClothing[]
  seasonRankings      SeasonRanking[]
  sessions            Session[]

  @@map("users")
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  type              String?   @default("oauth")
  provider          String
  providerAccountId String
  refresh_token     String?   @db.Text
  access_token      String?   @db.Text
  expires_at        DateTime? @db.DateTime(0)
  token_type        String?
  scope             String?
  id_token          String?   @db.Text
  session_state     String?
  createdAt         DateTime  @default(now()) @db.DateTime(0)
  updatedAt         DateTime  @default(now()) @db.DateTime(0)
  password          String?   @db.VarChar(255)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "accounts_userId_fkey")
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now()) @db.DateTime(0)
  updatedAt    DateTime @default(now()) @db.DateTime(0)
  ipAddress    String?  @db.VarChar(255)
  userAgent    String?  @db.Text
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_userId_fkey")
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Product {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String      @db.Text
  price         Float
  originalPrice Float?
  image         String      @db.Text
  images        String      @db.LongText
  categoryId    String
  subcategory   String?
  tags          String      @db.LongText
  specs         String?     @db.LongText
  stock         Int         @default(-1)
  maxPerUser    Int         @default(10)
  rating        Float       @default(0)
  soldCount     Int         @default(0)
  isActive      Boolean     @default(true)
  isLimited     Boolean     @default(false)
  isNew         Boolean     @default(false)
  isHot         Boolean     @default(false)
  discount      Int?        @default(0)
  gameItemId    String?
  deliveryType  String?
  deliveryData  String?     @db.LongText
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  isGiftable    Boolean     @default(true)
  isUnique      Boolean     @default(false)
  requiresGuild Boolean     @default(false)
  archivedAt    DateTime?
  deletedAt     DateTime?
  videoUrl      String?     @db.Text
  hasVariants   Boolean     @default(false)
  sellPercent   Float?
  favorites     Favorite[]
  orderItems    OrderItem[]
  commands      ProductCommand[]
  variants      ProductVariant[]
  category      Category    @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("products")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  color       String     @default("#00E676")
  icon        String     @default("package")
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  archivedAt  DateTime?
  deletedAt   DateTime?
  description String?    @db.Text
  href        String?
  isHot       Boolean    @default(false)
  parentId    String?
  image       String?    @db.Text
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@index([parentId])
  @@map("categories")
}

model Order {
  id                    String          @id @default(cuid())
  orderNumber           String          @unique
  userId                String
  total                 Float
  status                String          @default("PENDING")
  paymentMethod         String?
  deliveryStatus        String?         @default("QUEUED")
  playerInfo            String          @db.LongText
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  basePrice             Float?
  billingCity           String?
  billingComplement     String?
  billingNeighborhood   String?
  billingNumber         String?
  billingState          String?
  billingStreet         String?
  billingZipCode        String?
  bonusDiamonds         Int?
  buyerCpf              String?
  buyerEmail            String?
  buyerName             String?
  buyerPhone            String?
  cancelledAt           DateTime?
  checkoutCode          String?
  deliveredAt           DateTime?
  diamondAmount         Int?
  externalCustomerId    String?
  externalOrderId       String?
  externalTransactionId String?
  giftMessage           String?         @db.Text
  giftRecipientId       Int?
  isGift                Boolean         @default(false)
  orderUuid             String?
  paidAt                DateTime?
  totalDiamonds         Int?
  deliveryNotes         String?         @db.Text
  previousStatus        String?
  deliveryChoice        String?
  auditLogs             OrderAuditLog[]
  items                 OrderItem[]
  user                  User            @relation(fields: [userId], references: [id])
  payments              Payment[]
  scheduledCommands     ScheduledCommand[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id              String    @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  priceAtPurchase Float
  deliveryStatus  String?
  deliveredAt     DateTime?
  deliveryNotes   String?   @db.Text
  variantId       String?
  variantName     String?
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id])
  variant         ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId], map: "order_items_productId_fkey")
  @@map("order_items")
}

model Payment {
  id                   String    @id @default(cuid())
  orderId              String
  method               String
  externalId           String?
  status               String    @default("PENDING")
  amount               Float
  pixCode              String?   @db.Text
  pixQrCode            String?   @db.Text
  paidAt               DateTime?
  createdAt            DateTime  @default(now())
  currency             String?   @default("BRL")
  gatewayName          String?
  gatewayResponse      String?   @db.Text
  gatewayTransactionId String?
  paymentUpdatedAt     DateTime?
  paymentUrl           String?   @db.Text
  processedAt          DateTime?
  installmentAmount    Float?
  installments         Int?      @default(1)
  totalWithInterest    Float?
  order                Order     @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([externalId])
  @@map("payments")
}

model GCoinTransaction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Int
  balance   Int
  orderId   String?
  paymentId String?
  reason    String?  @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@index([orderId])
  @@map("gcoin_transactions")
}

model VipPlan {
  id             String    @id @default(cuid())
  name           String
  tier           String
  duration       String
  price          Float
  originalPrice  Float?
  benefits       String    @default("[]") @db.LongText
  exclusiveBenefits String? @db.LongText
  features       String    @default("[]") @db.LongText
  image          String?   @db.Text
  exclusiveImage String?   @db.Text
  isPopular      Boolean   @default(false)
  isBestValue    Boolean   @default(false)
  isActive       Boolean   @default(true)
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  archivedAt     DateTime?
  deletedAt      DateTime?
  imageBack      String?   @db.Text
  tierOrder      Int       @default(0)
  color          String?
  colorRgb       String?
  tagline        String?
  iconType       String?   @default("crown")
  commands       String    @default("[]") @db.LongText
  exclusiveCommands String? @db.LongText
  comparisonData String    @default("[]") @db.LongText
  updatedAt      DateTime  @default(now()) @updatedAt

  @@map("vip_plans")
}

model VipFaq {
  id         String    @id @default(cuid())
  question   String    @db.Text
  answer     String    @db.Text
  order      Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  archivedAt DateTime?

  @@map("vip_faqs")
}

model LootBoxTheme {
  id            String    @id @default(cuid())
  name          String    @unique
  imageClosed   String    @db.Text
  imageSemiOpen String?   @db.Text
  imageOpen     String?   @db.Text
  isDefault     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  archivedAt    DateTime?
  lootBoxes     LootBox[]

  @@map("loot_box_themes")
}

model LootBox {
  id            String             @id @default(cuid())
  name          String
  code          String             @unique
  description   String?            @db.Text
  image         String?            @db.Text
  price         Int
  isActive      Boolean            @default(true)
  commonRate    Float              @default(58)
  rareRate      Float              @default(28)
  epicRate      Float              @default(10)
  legendaryRate Float              @default(3)
  mythicalRate  Float              @default(1)
  defaultSellPercent Float?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  color         String?
  archivedAt    DateTime?
  deletedAt     DateTime?
  imageClosed   String?            @db.Text
  imageOpen     String?            @db.Text
  imageSemiOpen String?            @db.Text
  themeId       String?
  history       LootBoxHistory[]
  inventory     LootBoxInventory[]
  items         LootBoxItem[]
  theme         LootBoxTheme?      @relation(fields: [themeId], references: [id])

  @@index([themeId])
  @@map("loot_boxes")
}

model LootBoxItem {
  id                  String    @id @default(cuid())
  lootBoxId           String
  name                String
  tier                String
  image               String?   @db.Text
  gameItemId          String?
  deliveryType        String?
  categorySlug        String?
  deliveryData        String?   @db.LongText
  isActive            Boolean   @default(true)
  femaleImageUrl      String?   @db.Text
  isEnabled           Boolean   @default(true)
  isGloballyAvailable Boolean   @default(true)
  sellPercent         Float?
  archivedAt          DateTime?
  deletedAt           DateTime?
  lootBox             LootBox   @relation(fields: [lootBoxId], references: [id], onDelete: Cascade)

  @@index([lootBoxId])
  @@index([tier])
  @@map("loot_box_items")
}

model LootBoxHistory {
  id          String   @id @default(cuid())
  userId      String
  lootBoxId   String
  itemWonId   String?
  itemName    String?
  itemTier    String?
  gcoinsSpent Int
  createdAt   DateTime @default(now())
  lootBox     LootBox  @relation(fields: [lootBoxId], references: [id])

  @@index([userId])
  @@index([lootBoxId])
  @@index([createdAt(sort: Desc)])
  @@map("loot_box_history")
}

model LootBoxInventory {
  id            String              @id @default(cuid())
  userId        String
  lootBoxItemId String?
  lootBoxId     String
  itemName      String
  itemTier      String
  itemImage     String?             @db.Text
  gameItemId    String?
  deliveryType  String?
  categorySlug  String?
  status        String              @default("AVAILABLE")
  deliveredAt   DateTime?
  createdAt     DateTime            @default(now())
  origin        String              @default("LOOTBOX")
  lootBox       LootBox             @relation(fields: [lootBoxId], references: [id])
  listing       MarketplaceListing?

  @@index([userId])
  @@index([lootBoxId])
  @@index([status])
  @@index([origin])
  @@index([createdAt(sort: Desc)])
  @@map("loot_box_inventory")
}

model PlayerClothing {
  id             String    @id @default(cuid())
  userId         String
  clothingId     Int
  isLocked       Boolean   @default(false)
  unlockedAt     DateTime  @default(now())
  cooldownEndsAt DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clothingId])
  @@map("player_clothes_owned")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId], map: "favorites_productId_fkey")
  @@map("favorites")
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String   @db.Text
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  details    String   @db.Text
  ip         String?
  createdAt  DateTime @default(now())
  targetId   String?
  targetType String?
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@index([targetId])
  @@index([targetType, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model OrderAuditLog {
  id          String   @id @default(cuid())
  orderId     String
  orderItemId String?
  actorId     String
  actorName   String?
  actorRole   String
  action      String
  fromStatus  String?
  toStatus    String?
  details     String?  @db.Text
  reason      String?
  ipAddress   String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("order_audit_logs")
}

model News {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  subtitle      String?
  content       String    @db.Text
  image         String?   @db.Text
  category      String    @default("Servidor")
  categoryColor String    @default("#00E676")
  author        String    @default("KUSH Admin")
  authorAvatar  String?   @db.Text
  authorRole    String?   @default("Administrador")
  readTime      String?   @default("3 min")
  views         Int       @default(0)
  status        String    @default("DRAFT")
  publishedAt   DateTime?
  trashedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@map("news")
}

model GCoinPackage {
  id          String    @id @default(cuid())
  name        String
  gcoins      Int
  bonusGCoins Int       @default(0)
  price       Float
  image       String?   @db.Text
  isPopular   Boolean   @default(false)
  isBestValue Boolean   @default(false)
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?
  deletedAt   DateTime?

  @@map("gcoin_packages")
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("newsletters")
}

model Guild {
  id          String        @id @default(cuid())
  name        String        @unique
  tag         String        @unique
  description String?       @db.Text
  image       String?       @db.Text
  color       String        @default("#00E676")
  ownerId     String
  level       Int           @default(1)
  exp         Int           @default(0)
  maxMembers  Int           @default(10)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  archivedAt  DateTime?
  members     GuildMember[]
  owner       User          @relation("GuildOwner", fields: [ownerId], references: [id])

  @@index([ownerId])
  @@map("guilds")
}

model GuildMember {
  id       String   @id @default(cuid())
  guildId  String
  userId   String   @unique
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  guild    Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@map("guild_members")
}

model Ban {
  id         String    @id @default(cuid())
  userId     String
  reason     String    @db.Text
  bannedById String?
  type       String    @default("MANUAL")
  duration   Int?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  evidence   String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  bannedBy   User?     @relation("BanIssuer", fields: [bannedById], references: [id])
  user       User      @relation("BannedUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([isActive])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@index([bannedById], map: "bans_bannedById_fkey")
  @@map("bans")
}

model Game {
  id         String       @id
  mode       String       @default("CASUAL")
  map        String?
  status     String       @default("FINISHED")
  maxPlayers Int          @default(10)
  duration   Int?
  winnerId   String?
  metadata   String?      @db.LongText
  startedAt  DateTime?
  endedAt    DateTime?
  createdAt  DateTime     @default(now())
  format     String       @default("SOLO")
  type       String       @default("ARENA")
  winnerTeam Int?
  players    GamePlayer[]

  @@index([mode])
  @@index([type])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("games")
}

model GamePlayer {
  id        String  @id @default(cuid())
  gameId    String
  userId    String
  team      String?
  kills     Int     @default(0)
  deaths    Int     @default(0)
  score     Int     @default(0)
  headshots Int     @default(0)
  isWinner  Boolean @default(false)
  position  Int?
  metadata  String? @db.LongText
  game      Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
  @@index([isWinner])
  @@map("game_players")
}

model Contact {
  id         String    @id @default(cuid())
  name       String
  email      String
  subject    String    @db.Text
  message    String    @db.Text
  read       Boolean   @default(false)
  starred    Boolean   @default(false)
  archived   Boolean   @default(false)
  deleted    Boolean   @default(false)
  deletedAt  DateTime?
  label      String?
  notes      String?   @db.Text
  status     String    @default("unread")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  @@index([read])
  @@index([starred])
  @@index([archived])
  @@index([deleted])
  @@index([label])
  @@index([createdAt(sort: Desc)])
  @@map("contacts")
}

model BackupConfig {
  id             String   @id @default(cuid())
  hostingType    String   @default("vercel")
  storageType    String   @default("local")
  autoBackup     Boolean  @default(false)
  frequency      String   @default("daily")
  backupTime     String   @default("03:00")
  emailNotify    Boolean  @default(true)
  notifyEmail    String   @default("")
  backupDatabase Boolean  @default(true)
  backupUploads  Boolean  @default(true)
  keepBackups    Int      @default(7)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("backup_configs")
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_configs")
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  template  String
  subject   String
  orderId   String?
  userId    String?
  success   Boolean  @default(false)
  error     String?  @db.Text
  resendId  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([template])
  @@index([createdAt(sort: Desc)])
  @@map("email_logs")
}

model BackupHistory {
  id        String   @id @default(cuid())
  type      String
  status    String
  size      Int?
  duration  Int?
  filePath  String?  @db.Text
  error     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("backup_history")
}

model HomeSection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  order       Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  archivedAt  DateTime?

  @@map("home_sections")
}

model FooterColumn {
  id     String       @id @default(cuid())
  name   String
  slug   String       @unique
  order  Int          @default(0)
  active Boolean      @default(true)
  items  FooterItem[]

  @@map("footer_columns")
}

model FooterItem {
  id       String       @id @default(cuid())
  label    String
  href     String
  order    Int          @default(0)
  active   Boolean      @default(true)
  columnId String
  column   FooterColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@index([columnId])
  @@map("footer_items")
}

model GameStats {
  id           String   @id @default(cuid())
  userId       String
  gameType     String
  kills        Int      @default(0)
  deaths       Int      @default(0)
  headshots    Int      @default(0)
  wins         Int      @default(0)
  matches      Int      @default(0)
  playedTimeMs BigInt   @default(0)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameType])
  @@index([gameType, kills])
  @@map("game_stats")
}

model Season {
  id          String          @id @default(cuid())
  name        String
  externalId  BigInt?         @unique
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  description String?         @db.Text
  prizes      String?         @db.LongText
  deletedAt   DateTime?
  archivedAt  DateTime?
  rankings    SeasonRanking[]

  @@map("seasons")
}

model SeasonRanking {
  id        String  @id @default(cuid())
  seasonId  String
  userId    String
  gameType  String?
  kills     Int     @default(0)
  deaths    Int     @default(0)
  headshots Int     @default(0)
  wins      Int     @default(0)
  matches   Int     @default(0)
  position  Int?
  season    Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId, gameType])
  @@index([seasonId, kills])
  @@index([userId], map: "season_rankings_userId_fkey")
  @@map("season_rankings")
}

model MarketplaceListing {
  id                String           @id @default(cuid())
  sellerId          String
  inventoryItemId   String           @unique
  itemName          String
  itemTier          String
  itemImage         String?          @db.Text
  itemCategory      String?
  itemOriginalPrice Int?
  askingPrice       Int
  suggestedPrice    Int?
  status            String           @default("ACTIVE")
  isAnonymous       Boolean          @default(false)
  buyerId           String?
  soldAt            DateTime?
  siteFeePercent    Float            @default(5)
  siteFeeAmount     Int?
  sellerReceived    Int?
  expiresAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  buyer             User?            @relation("MarketplaceBuyer", fields: [buyerId], references: [id])
  inventoryItem     LootBoxInventory @relation(fields: [inventoryItemId], references: [id])
  seller            User             @relation("MarketplaceSeller", fields: [sellerId], references: [id])

  @@index([status])
  @@index([sellerId])
  @@index([buyerId])
  @@index([itemTier])
  @@index([itemCategory])
  @@index([askingPrice])
  @@index([createdAt(sort: Desc)])
  @@index([status, itemTier])
  @@index([status, askingPrice])
  @@fulltext([itemName])
  @@map("marketplace_listings")
}

model MarketplaceTransaction {
  id              String   @id @default(cuid())
  listingId       String?
  sellerId        String
  buyerId         String?
  itemName        String
  itemTier        String
  itemInventoryId String
  salePrice       Int
  siteFee         Int
  sellerReceived  Int
  type            String
  createdAt       DateTime @default(now())
  itemImage       String?  @db.Text
  buyer           User?    @relation("TransactionBuyer", fields: [buyerId], references: [id])
  seller          User     @relation("TransactionSeller", fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([buyerId])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@map("marketplace_transactions")
}

model MenuItem {
  id          String     @id @default(cuid())
  label       String
  href        String?
  icon        String?
  type        String     @default("link")
  target      String?
  badge       String?
  badgeColor  String?
  parentId    String?
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  isAuthOnly  Boolean    @default(false)
  color       String?
  image       String?
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  archivedAt  DateTime?
  parent      MenuItem?  @relation("MenuChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    MenuItem[] @relation("MenuChildren")

  @@index([parentId])
  @@index([order])
  @@index([isActive])
  @@map("menu_items")
}

model verification {
  id         String   @id
  identifier String   @db.VarChar(255)
  value      String   @db.Text
  expiresAt  DateTime @db.DateTime(0)
  createdAt  DateTime @default(now()) @db.DateTime(0)
  updatedAt  DateTime @default(now()) @db.DateTime(0)
}

model GameLink {
  id            String   @id @default(cuid())
  game          String   @unique
  platform      String   @default("fivem")
  name          String
  serverCode    String
  serverUrl     String?  @db.VarChar(500)
  serverIp      String?  @db.VarChar(50)
  serverPort    Int?
  instagram     String?  @db.VarChar(100)
  discordInvite String?  @db.VarChar(100)
  videoPath     String?  @db.VarChar(500)
  thumbnailUrl  String?  @db.Text
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("game_links")
}

model CommandPreset {
  id          String           @id @default(cuid())
  index       String           @unique
  label       String
  description String?          @db.Text
  template    String?          @db.Text
  isActive    Boolean          @default(true)
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  commands    ProductCommand[]

  @@map("command_presets")
}

model ProductVariant {
  id            String           @id @default(cuid())
  productId     String
  name          String
  price         Float
  originalPrice Float?
  image         String?          @db.Text
  benefits      String?          @db.LongText
  deliveryData  String?          @db.LongText
  duration      Int?
  order         Int              @default(0)
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  commands      ProductCommand[]
  orderItems    OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductCommand {
  id        String          @id @default(cuid())
  productId String
  variantId String?
  presetId  String?
  trigger   String          @default("AFTER_PURCHASE")
  command   String          @db.Text
  order     Int             @default(0)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  preset    CommandPreset?  @relation(fields: [presetId], references: [id])

  @@index([productId])
  @@index([variantId])
  @@index([presetId])
  @@map("product_commands")
}

model ScheduledCommand {
  id          String    @id @default(cuid())
  orderId     String
  orderItemId String?
  userId      String
  playerId    String
  command     String    @db.Text
  executeAt   DateTime
  executedAt  DateTime?
  status      String    @default("PENDING")
  attempts    Int       @default(0)
  lastError   String?   @db.Text
  createdAt   DateTime  @default(now())
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, executeAt])
  @@index([orderId])
  @@map("scheduled_commands")
}